# Copy this file to .env and fill in your key
# cp .env.example .env

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# SmartCredit MCP URL (optional — defaults to the public endpoint, no auth required)
SMARTCREDIT_MCP_URL=https://mcp.smartcredit.io/web3-borrow-lend-mcp

# ── Aave V3 Active Positions Fetcher ─────────────────────────────────────────
# Public RPC for eth_call (no archive node needed — log fetching uses Etherscan)
RPC_URL=https://ethereum.publicnode.com

# Blocks per Etherscan getLogs call
BLOCK_CHUNK_SIZE=2000

# Etherscan API key — https://etherscan.io/myapikey (free tier works)
ETHERSCAN_API_KEY=

# Default position filters (all overridable via CLI flags)
MIN_DEBT_USD=0
MAX_HF=999
